    e.preventDefault();
    
    const submitBtn = e.target.querySelector('button[type="submit"]');
    const originalText = submitBtn.innerHTML;
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري الإضافة...';
    
    const formData = new FormData(this);
    formData.append('action', 'add_courier');
    
    try {
        const response = await fetch('api/manage_courier.php', {
            method: 'POST',
            body: formData
        });
        
        const data = await response.json();
        
        if (data.success) {
            // Success message with portal URL
            const message = `✅ ${data.message}\n\n` +
                          `📱 رابط تسجيل الدخول:\n${data.portal_url}\n\n` +
                          `👤 اسم المستخدم: ${formData.get('username')}\n` +
                          `🔑 كلمة المرور: ${formData.get('password')}\n\n` +
                          `⚠️ احفظ هذه المعلومات وأرسلها للموصل`;
            
            alert(message);
            closeAddCourierModal();
            loadCouriers();
        } else {
            alert('❌ خطأ: ' + data.error);
        }
    } catch (error) {
        alert('❌ حدث خطأ في الاتصال');
        console.error(error);
    }
    
    submitBtn.disabled = false;
    submitBtn.innerHTML = originalText;
});

async function loadCouriers() {
    try {
        const formData = new FormData();
        formData.append('action', 'list_couriers');
        
        const response = await fetch('api/manage_courier.php', {
            method: 'POST',
            body: formData
        });
        
        const data = await response.json();
        
        if (data.success) {
            const container = document.getElementById('couriersList');
            const couriers = data.couriers;
            
            // Update statistics
            document.getElementById('totalCouriers').textContent = couriers.length;
            document.getElementById('activeCouriers').textContent = couriers.length; // TODO: filter active
            
            let totalDeliveries = 0;
            let totalCOD = 0;
            
            couriers.forEach(c => {
                totalDeliveries += parseInt(c.completed_deliveries);
                totalCOD += parseFloat(c.total_cod_collected);
            });
            
            document.getElementById('totalDeliveries').textContent = totalDeliveries;
            document.getElementById('totalCOD').textContent = totalCOD.toFixed(2) + ' ر.س';
            
            if (couriers.length === 0) {
                container.innerHTML = `
                    <div style="text-align: center; padding: 4rem; color: #6b7280;">
                        <i class="fas fa-truck" style="font-size: 4rem; opacity: 0.3; margin-bottom: 1rem;"></i>
                        <p style="font-size: 1.125rem; font-weight: 600;">لا يوجد موصلين حالياً</p>
                        <p style="margin-top: 0.5rem;">اضغط "إضافة موصل جديد" للبدء</p>
                    </div>
                `;
                return;
            }
            
            container.innerHTML = `
                <table style="width: 100%; border-collapse: collapse; background: white; border-radius: 8px; overflow: hidden;">
                    <thead>
                        <tr style="background: linear-gradient(135deg, #f9fafb, #f3f4f6); border-bottom: 2px solid #e5e7eb;">
                            <th style="padding: 1rem; text-align: right; font-weight: 700; color: #374151;">الاسم</th>
                            <th style="padding: 1rem; text-align: right; font-weight: 700; color: #374151;">اسم المستخدم</th>
                            <th style="padding: 1rem; text-align: right; font-weight: 700; color: #374151;">الجوال</th>
                            <th style="padding: 1rem; text-align: center; font-weight: 700; color: #374151;">الطلبات</th>
                            <th style="padding: 1rem; text-align: center; font-weight: 700; color: #374151;">المكتملة</th>
                            <th style="padding: 1rem; text-align: center; font-weight: 700; color: #374151;">COD المحصّل</th>
                            <th style="padding: 1rem; text-align: center; font-weight: 700; color: #374151;">تاريخ الإضافة</th>
                            <th style="padding: 1rem; text-align: center; font-weight: 700; color: #374151;">الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${couriers.map((c, index) => `
                            <tr style="border-bottom: 1px solid #e5e7eb; transition: background 0.2s;" onmouseover="this.style.background='#f9fafb'" onmouseout="this.style.background='white'">
                                <td style="padding: 1rem;">
                                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                                        <div style="width: 40px; height: 40px; background: linear-gradient(135deg, #10b981, #059669); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: 700;">
                                            ${(c.username || 'C').charAt(0).toUpperCase()}
                                        </div>
                                        <strong>${c.username || 'موصل'}</strong>
                                    </div>
                                </td>
                                <td style="padding: 1rem; color: #6b7280;">${c.username}</td>
                                <td style="padding: 1rem;">
                                    ${c.phone ? `<a href="tel:${c.phone}" style="color: #10b981; text-decoration: none;"><i class="fas fa-phone"></i> ${c.phone}</a>` : '-'}
                                </td>
                                <td style="padding: 1rem; text-align: center;">
                                    <span style="background: #dbeafe; color: #1e40af; padding: 0.25rem 0.75rem; border-radius: 12px; font-weight: 600;">
                                        ${c.total_assignments}
                                    </span>
                                </td>
                                <td style="padding: 1rem; text-align: center;">
                                    <span style="background: #d1fae5; color: #065f46; padding: 0.25rem 0.75rem; border-radius: 12px; font-weight: 600;">
                                        ${c.completed_deliveries}
                                    </span>
                                </td>
                                <td style="padding: 1rem; text-align: center; font-weight: 700; color: #059669;">
                                    ${parseFloat(c.total_cod_collected).toFixed(2)} ر.س
                                </td>
                                <td style="padding: 1rem; text-align: center; font-size: 0.875rem; color: #6b7280;">
                                    ${new Date(c.created_at).toLocaleDateString('ar-SA')}
                                </td>
                                <td style="padding: 1rem; text-align: center;">
                                    <button onclick="viewCourierDetails(${c.id})" style="background: #3b82f6; color: white; padding: 0.5rem 1rem; border-radius: 6px; border: none; cursor: pointer; font-size: 0.875rem; margin: 0 0.25rem;">
                                        <i class="fas fa-eye"></i> عرض
                                    </button>
                                </td>
                            </tr>
                        `).join('')}
                    </tbody>
                </table>
            `;
        }
    } catch (error) {
        console.error('Error loading couriers:', error);
    }
}

function viewCourierDetails(courierId) {
    alert('عرض تفاصيل الموصل #' + courierId + '\n(سيتم تطويرها لاحقاً)');
}

// Load couriers on page load
loadCouriers();

// Refresh every 30 seconds
setInterval(loadCouriers, 30000);
</script>

