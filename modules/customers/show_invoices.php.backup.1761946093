                        <?php endif; ?>
                    </p>
                </div>
            <?php else: ?>
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th>رقم الفاتورة</th>
                            <th>اسم العميل</th>
                            <th>الحالة</th>
                            <th>المبلغ الإجمالي</th>
                            <th class="text-green-600">المدفوع</th>
                            <th class="text-red-600">المتبقي</th>
                            <th>تاريخ الاستحقاق</th>
                            <th style="width: 150px;">إجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        <?php foreach ($invoices as $invoice): 
                            // Determine the final status text based on real financial data
                            $status_text = $invoice['status'];
                            if ($invoice['remaining_amount'] <= 0) {
                                $status_text = 'Paid';
                            } elseif ($invoice['paid_amount'] > 0) {
                                $status_text = 'Partially Paid';
                            }
                        ?>
                            <tr class="hover:bg-gray-50">
                                <td><strong><?php echo htmlspecialchars($invoice['invoice_number'] ?? 'N/A'); ?></strong></td>
                                <td><?php echo htmlspecialchars($invoice['customer_name'] ?? 'عميل غير محدد'); ?></td>
                                <td>
                                    <span class="status-badge <?php echo getStatusClass($invoice['status'], $invoice['remaining_amount']); ?>">
                                        <?php echo htmlspecialchars(str_replace('_', ' ', $status_text)); ?>
                                    </span>
                                </td>
                                <td><strong><?php echo number_format($invoice['total_amount'] ?? 0, 2); ?> ر.س</strong></td>
                                <td class="font-semibold text-green-600"><?php echo number_format($invoice['paid_amount'] ?? 0, 2); ?> ر.س</td>
                                <td class="font-semibold text-red-600"><?php echo number_format($invoice['remaining_amount'] ?? 0, 2); ?> ر.س</td>
