<?php
/**
 * Customer Invoices - Index Page
 * صفحة عرض فواتير العملاء مع حساب المبالغ المدفوعة والمتبقية
 */

// --- 1. INITIALIZATION & SECURITY ---
session_start();
if (!isset($_SESSION['user_id'])) {
    header('Location: ../../login.php');
    exit();
}

// --- 2. DATABASE & CONFIGURATION ---
require_once '../../config/database.php';

$page_title = 'فواتير العملاء';
$error_message = '';
$invoices = [];

// --- 3. FETCH INVOICES FROM DATABASE (WITH CORRECTIONS) ---
try {
    // **FIXED**: The query now calculates paid and remaining amounts for each invoice.
   $sql = "
        SELECT 
            ci.id,
            ci.invoice_number,
            ci.total_amount,
            ci.status,
            ci.due_date,
            ci.created_at,
            c.name AS customer_name,
            u.username AS created_by_user,
            
            -- CORRECTED: Combine initial order payment + later invoice payments
            (
                COALESCE(co.paid_amount, 0) + 
                COALESCE((SELECT SUM(cp.amount) FROM customer_payments cp WHERE cp.invoice_id = ci.id), 0)
            ) as paid_amount,
            
            -- CORRECTED: Recalculate remaining amount based on the true total paid
            (
                ci.total_amount - 
                (
                    COALESCE(co.paid_amount, 0) + 
                    COALESCE((SELECT SUM(cp.amount) FROM customer_payments cp WHERE cp.invoice_id = ci.id), 0)
                )
            ) as remaining_amount
            
        FROM 
            customer_invoices ci
        LEFT JOIN 
            customers c ON ci.customer_id = c.id
        LEFT JOIN 
            users u ON ci.created_by = u.id
        -- ADDED JOIN: This is necessary to get the initial paid amount from the order
        LEFT JOIN 
            customer_orders co ON ci.order_id = co.id
    ";

    // Handle search functionality
    $search_term = isset($_GET['search']) ? trim((string)$_GET['search']) : '';
    $params = [];
    if (!empty($search_term)) {
        $sql .= " WHERE (ci.invoice_number LIKE :search OR c.name LIKE :search OR ci.status LIKE :search)";
        $params[':search'] = '%' . $search_term . '%';
    }

    $sql .= " ORDER BY ci.created_at DESC";
    $stmt = $db->prepare($sql);
    $stmt->execute($params);
    $invoices = $stmt->fetchAll(PDO::FETCH_ASSOC);

} catch (Exception $e) {
    $error_message = "حدث خطأ أثناء جلب البيانات: " . $e->getMessage();
}

// **UPDATED**: This function now considers the remaining amount for accurate status coloring.
function getStatusClass($status, $remaining_amount) {
    if ($remaining_amount <= 0) {
        return 'status-paid'; // Green if fully paid
    }
    switch (strtolower($status)) {
        case 'partially_paid':
            return 'status-partial'; // Orange for partial payments
        case 'overdue':
            return 'status-overdue'; // Red for overdue
        case 'cancelled':
            return 'status-cancelled'; // Gray for cancelled
        case 'pending':
        default:
            return 'status-pending'; // Yellow for pending
    }
}

// --- 4. RENDER THE PAGE ---
include '../../includes/header.php';
?>

