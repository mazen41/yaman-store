<?php
/**
 * Unified Purchase Groups - Manual & Auto
 * Now displays both manually added groups and auto-generated groups from baskets.
 */

session_start();

if (!isset($_SESSION['user_id'])) {
    header('Location: ../../../login.php');
    exit();
}

require_once '../../../config/database.php';

$page_title = 'مجموعات الشراء';
$error_message = '';
$groups = [];

try {
    // --- QUERY 1: Fetch MANUALLY created groups from the `purchase_groups` table ---
    $manual_groups_query = "
        SELECT 
            pg.id,
            pg.group_number as group_code,
            pg.group_name,
            pg.description,
            pg.start_date as purchase_date,
            pg.status,
            pg.created_at,
            pg.notes,
            -- These fields don't directly apply to manual groups but are needed for UNION
            NULL as basket_id,
            'manual' as group_type, -- Add a type identifier
            -- Calculate totals if linked, otherwise show 0
            (SELECT COUNT(DISTINCT po.id) FROM purchase_orders po WHERE po.purchase_group_id = pg.id) as orders_count,
            (SELECT SUM(poi.quantity * poi.unit_price) FROM purchase_order_items poi JOIN purchase_orders po ON poi.purchase_order_id = po.id WHERE po.purchase_group_id = pg.id) as total_amount,
            u.username as created_by_user
        FROM 
            purchase_groups pg
        LEFT JOIN
            users u ON pg.created_by = u.id
    ";

    // --- QUERY 2: Fetch AUTO-GENERATED groups from the `purchase_baskets` table ---
    $auto_groups_query = "
        SELECT 
            NULL as id, -- No direct ID in the groups table
            CONCAT('PG-AUTO-', pb.id) as group_code,
            CONCAT('مجموعة تلقائية - سلة #', pb.id) as group_name,
            'تم إنشاؤها تلقائياً من سلة المشتريات' as description,
            pb.purchase_date,
            pb.status,
            pb.created_at,
            NULL as notes,
            pb.id as basket_id,
            'auto' as group_type, -- Add a type identifier
            COUNT(DISTINCT bi.order_id) as orders_count,
            SUM(COALESCE(bi.total_price, 0)) as total_amount,
            u_pb.username as created_by_user
        FROM 
            purchase_baskets pb
        LEFT JOIN 
            basket_items bi ON pb.id = bi.basket_id
        LEFT JOIN
            users u_pb ON pb.created_by = u_pb.id
        GROUP BY 
            pb.id
    ";

    // --- COMBINE both queries using UNION ALL ---
    $final_query = "
        ($manual_groups_query)
        UNION ALL
        ($auto_groups_query)
        ORDER BY created_at DESC
    ";
    
    $stmt = $db->prepare($final_query);
    $stmt->execute();
    $groups = $stmt->fetchAll(PDO::FETCH_ASSOC);

} catch (PDOException $e) {
    $error_message = 'حدث خطأ أثناء جلب البيانات: ' . $e->getMessage();
}

