            <?php if ($error_message): ?>
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg m-6">
                <strong>❌ خطأ:</strong> <?php echo $error_message; ?>
            </div>
            <?php endif; ?>

            <?php if ($success_message): ?>
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg m-6">
                <strong><?php echo $success_message; ?></strong>
                <div class="mt-3 text-sm space-y-1">
                    <p><strong>المبلغ الإجمالي:</strong> <?php echo number_format($invoice['total_amount'], 2); ?> ريال</p>
                    <p><strong>المبلغ المدفوع:</strong> <?php echo number_format($invoice['paid_amount'], 2); ?> ريال</p>
                    <p><strong>المتبقي:</strong> <?php echo number_format($remaining, 2); ?> ريال</p>
                    <p><strong>الحالة:</strong> 
                        <?php 
                        if ($invoice['status'] == 'paid') echo '<span class="text-green-600 font-bold">✅ مدفوع</span>';
                        elseif ($invoice['status'] == 'partially_paid') echo '<span class="text-yellow-600 font-bold">⚠️ مدفوع جزئياً</span>';
                        else echo '<span class="text-red-600 font-bold">⏳ معلق</span>';
                        ?>
                    </p>
                </div>
                <div class="mt-4">
                    <a href="../customers/show_invoices.php" class="inline-block px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
                        ← العودة إلى قائمة الفواتير
                    </a>
                </div>
            </div>
            <?php endif; ?>

            <?php if ($remaining > 0 && !$success_message): ?>
            <form method="POST" enctype="multipart/form-data" enctype="multipart/form-data" class="p-6 space-y-4" id="paymentForm" enctype="multipart/form-data">
                <!-- Invoice Summary -->
                <div class="bg-blue-50 p-4 rounded-lg border border-blue-200">
                    <h3 class="font-bold text-lg mb-2">ملخص الفاتورة</h3>
                    <div class="grid grid-cols-2 gap-3 text-sm">
                        <div>
                            <span class="text-gray-600">المبلغ الإجمالي:</span>
                            <span class="font-bold"><?php echo number_format($invoice['total_amount'], 2); ?> ريال</span>
                        </div>
                        <div>
                            <span class="text-gray-600">المدفوع حالياً:</span>
                            <span class="font-bold text-green-600"><?php echo number_format($invoice['paid_amount'], 2); ?> ريال</span>
                        </div>
                        <div class="col-span-2">
                            <span class="text-gray-600">المتبقي:</span>
                            <span class="font-bold text-red-600 text-xl"><?php echo number_format($remaining, 2); ?> ريال</span>
                        </div>
                    </div>
                </div>

                <!-- Payment Amount -->
                <div>
                    <label for="amount" class="block text-sm font-medium text-gray-700 mb-1">
                        مبلغ الدفعة * <span class="text-xs text-gray-500">(الحد الأقصى: <?php echo number_format($remaining, 2); ?> ريال)</span>
                    </label>
                    <input 
                        type="number" 
                        id="amount" 
                        name="amount" 
                        step="0.01" 
                        min="0.01" 
                        max="<?php echo $remaining; ?>" 
                        value="<?php echo $remaining; ?>"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" 
                        required
                    >
                </div>

                <!-- Payment Method -->
                <div>
                    <label for="payment_method" class="block text-sm font-medium text-gray-700 mb-1">طريقة الدفع *</label>
                    <select id="payment_method" name="payment_method" class="w-full px-4 py-2 border border-gray-300 rounded-lg" required>
                        <option value="">-- اختر طريقة الدفع --</option>
                        <option value="cash">نقدي</option>
