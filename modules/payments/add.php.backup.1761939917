<?php
session_start();
if (!isset($_SESSION['user_id'])) {
    header('Location: ../../login.php');
    exit();
}

require_once '../../config/database.php';

$page_title = 'إضافة دفعة';
$error_message = '';
$success_message = '';
$loading = false;

// Get invoice ID
$invoice_id = intval($_GET['invoice_id'] ?? 0);
if (!$invoice_id) {
    header('Location: ../customers/show_invoices.php');
    exit();
}

// Fetch invoice with RECALCULATED paid_amount
$stmt = $db->prepare("
    SELECT 
        ci.*,
        COALESCE((SELECT SUM(amount) FROM customer_payments WHERE invoice_id = ci.id), 0) as actual_paid,
        co.order_number,
        c.name as customer_name
    FROM customer_invoices ci
    LEFT JOIN customer_orders co ON ci.order_id = co.id
    LEFT JOIN customers c ON ci.customer_id = c.id
    WHERE ci.id = ?
");
$stmt->execute([$invoice_id]);
$invoice = $stmt->fetch(PDO::FETCH_ASSOC);

if (!$invoice) {
    header('Location: ../customers/show_invoices.php');
    exit();
}

// Use ACTUAL paid from SUM, not stored value
$invoice['paid_amount'] = $invoice['actual_paid'];
$remaining = max(0, $invoice['total_amount'] - $invoice['paid_amount']);

// Handle form submission with CORRECT LOGIC
if ($_SERVER['REQUEST_METHOD'] == 'POST') {
    $amount = floatval($_POST['amount'] ?? 0);
    $payment_method = trim($_POST['payment_method'] ?? '');
    $payment_date = $_POST['payment_date'] ?? date('Y-m-d');
    $notes = trim($_POST['notes'] ?? '');
    
    // VALIDATION (prevent overpayment)
    if ($amount <= 0) {
        $error_message = 'المبلغ يجب أن يكون أكبر من صفر';
    } elseif (empty($payment_method)) {
        $error_message = 'يرجى اختيار طريقة الدفع';
    } elseif ($amount > $remaining) {
        $error_message = sprintf(
            'خطأ: المبلغ (%.2f ريال) أكبر من المتبقي (%.2f ريال)',
            $amount,
            $remaining
        );
    } else {
        try {
            // ATOMIC TRANSACTION with CORRECT LOGIC
            $db->beginTransaction();
            
            // 1. Check for duplicate (idempotency - prevent double-click)
            $stmt = $db->prepare("
                SELECT COUNT(*) FROM customer_payments 
                WHERE invoice_id = ? 
                AND amount = ? 
                AND created_at > DATE_SUB(NOW(), INTERVAL 5 SECOND)
            ");
            $stmt->execute([$invoice_id, $amount]);
            if ($stmt->fetchColumn() > 0) {
                throw new Exception('طلب مكرر - تم إضافة هذه الدفعة للتو');
            }
            
            // 2. Generate payment number
            $payment_count = $db->query("SELECT COUNT(*) FROM customer_payments")->fetchColumn();
            $payment_number = 'PAY-' . date('Ymd') . '-' . str_pad($payment_count + 1, 8, '0', STR_PAD_LEFT);
            
            // 3. Insert payment
            $stmt = $db->prepare("
                INSERT INTO customer_payments 
                (payment_number, customer_id, invoice_id, amount, currency, payment_method, 
                 payment_date, notes, created_by, created_at, updated_at)
                VALUES (?, ?, ?, ?, 'SAR', ?, ?, ?, ?, NOW(), NOW())
            ");
            $stmt->execute([
                $payment_number,
                $invoice['customer_id'],
                $invoice_id,
                $amount,
                $payment_method,
                $payment_date,
                $notes,
                $_SESSION['user_id']
            ]);
            
            // 4. RECALCULATE paid_amount using SUM (CORRECT LOGIC - not +=)
            $stmt = $db->prepare("
                UPDATE customer_invoices 
                SET paid_amount = (
                    SELECT COALESCE(SUM(amount), 0) 
                    FROM customer_payments 
                    WHERE invoice_id = ?
                ),
                updated_at = NOW()
                WHERE id = ?
            ");
            $stmt->execute([$invoice_id, $invoice_id]);
            
            // 5. Calculate remaining with MAX guard
            $stmt = $db->prepare("
                UPDATE customer_invoices 
                SET remaining_amount = GREATEST(0, total_amount - paid_amount)
                WHERE id = ?
            ");
            $stmt->execute([$invoice_id]);
            
            // 6. Update status with CORRECT conditional logic
            $stmt = $db->prepare("
                UPDATE customer_invoices 
                SET status = CASE
                    WHEN paid_amount = 0 THEN 'pending'
                    WHEN paid_amount >= total_amount THEN 'paid'
                    WHEN paid_amount > 0 AND paid_amount < total_amount THEN 'partially_paid'
                    ELSE 'pending'
                END,
                updated_at = NOW()
                WHERE id = ?
            ");
            $stmt->execute([$invoice_id]);
            
            // 7. Sync order (if exists)
            if ($invoice['order_id']) {
                // Recalculate order paid_amount using SUM
                $stmt = $db->prepare("
                    UPDATE customer_orders 
                    SET paid_amount = (
                        SELECT COALESCE(SUM(cp.amount), 0)
                        FROM customer_payments cp
                        INNER JOIN customer_invoices ci ON cp.invoice_id = ci.id
                        WHERE ci.order_id = ?
                    ),
                    updated_at = NOW()
                    WHERE id = ?
                ");
                $stmt->execute([$invoice['order_id'], $invoice['order_id']]);
                
                // Update order status
                $stmt = $db->prepare("
                    UPDATE customer_orders 
                    SET status = CASE
                        WHEN paid_amount >= final_amount THEN 'completed'
                        WHEN paid_amount > 0 THEN 'processing'
                        ELSE status
                    END,
                    updated_at = NOW()
                    WHERE id = ?
                ");
                $stmt->execute([$invoice['order_id']]);
            }
            
            // COMMIT
            $db->commit();
            
            // Refresh invoice data
            $stmt = $db->prepare("
                SELECT *,
                COALESCE((SELECT SUM(amount) FROM customer_payments WHERE invoice_id = id), 0) as actual_paid
                FROM customer_invoices WHERE id = ?
            ");
            $stmt->execute([$invoice_id]);
            $invoice = $stmt->fetch(PDO::FETCH_ASSOC);
            $invoice['paid_amount'] = $invoice['actual_paid'];
            $remaining = max(0, $invoice['total_amount'] - $invoice['paid_amount']);
            
            $success_message = "✅ تم إضافة الدفعة بنجاح - رقم الدفعة: {$payment_number}";
            
        } catch (Exception $e) {
            $db->rollBack();
            $error_message = 'حدث خطأ: ' . $e->getMessage();
        }
    }
}

include '../../includes/header.php';
?>

<div class="min-h-screen bg-gray-50 py-6" dir="rtl">
    <div class="max-w-2xl mx-auto px-4">
        <div class="bg-white shadow rounded-lg">
            <div class="px-6 py-4 border-b bg-blue-600 text-white rounded-t-lg">
                <h1 class="text-xl font-bold">إضافة دفعة للفاتورة #<?php echo htmlspecialchars($invoice['invoice_number']); ?></h1>
