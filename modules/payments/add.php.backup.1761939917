                        <option value="credit_card">بطاقة ائتمانية</option>
                        <option value="check">شيك</option>
                    </select>
                </div>

                <!-- Payment Date -->
                <div>

                <!-- الحساب البنكي -->
                <div class="mb-4" id="bank_account_field" style="display: none;">
                    <label for="bank_account_id" class="block text-sm font-medium text-gray-700 mb-1">
                        الحساب البنكي <span class="text-red-500">*</span>
                    </label>
                    <select name="bank_account_id" id="bank_account_id" 
                            class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500">
